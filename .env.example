# Trading Bot Environment Variables
# Copy this file to .env and fill in your values

# Exchange API Keys (leave empty for paper trading)
BINANCE_API_KEY=
BINANCE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Discord Webhook URL (optional)
DISCORD_WEBHOOK_URL=

# Flask Secret Key (generate a random string for production)
FLASK_SECRET_KEY=your-secret-key-here

# Paper Trading (set to 'false' for real trading)
PAPER_TRADING=true