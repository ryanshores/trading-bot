# Trading Bot Environment Variables
# Copy this file to .env and fill in your values
# All variables have defaults in config.py - only override what you need

# ===================================
# Exchange Configuration
# ===================================

# Exchange name: binance, kraken
EXCHANGE_NAME=binance

# Exchange API credentials (leave empty for paper trading)
EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=

# Use testnet/sandbox (true/false) - not applicable to Kraken
EXCHANGE_TESTNET=true

# ===================================
# Trading Configuration
# ===================================

# Trading pair (e.g., BTCUSDT, ETHUSDT)
TRADING_SYMBOL=BTCUSDT

# Candle timeframe: 1m, 5m, 15m, 1h, 4h, 1d
TRADING_TIMEFRAME=1h

# Paper trading mode (true = fake money, false = real trades)
PAPER_TRADING=true

# Risk Management
MAX_POSITION_SIZE=100
STOP_LOSS_PERCENT=2
TAKE_PROFIT_PERCENT=4
MAX_OPEN_POSITIONS=3
DAILY_LOSS_LIMIT=1000

# ===================================
# Strategy Configuration
# ===================================

# Strategy: trend_following, mean_reversion
STRATEGY_NAME=trend_following

# Trend Following Parameters
STRATEGY_SHORT_MA=20
STRATEGY_LONG_MA=50
STRATEGY_RSI_PERIOD=14
STRATEGY_RSI_OVERBOUGHT=70
STRATEGY_RSI_OVERSOLD=30

# Mean Reversion Parameters (Bollinger Bands)
STRATEGY_BB_PERIOD=20
STRATEGY_BB_STD=2

# ===================================
# Discord Notifications (Optional)
# ===================================

# Discord webhook URL (leave empty to disable)
DISCORD_WEBHOOK_URL=

# Notification preferences (true/false)
NOTIFY_ON_BUY=true
NOTIFY_ON_SELL=true
NOTIFY_ON_ERROR=true
DAILY_SUMMARY=true
SUMMARY_TIME=20:00

# ===================================
# Flask/Dashboard Configuration
# ===================================

# Secret key for Flask sessions (generate a random string for production)
FLASK_SECRET_KEY=your-secret-key-change-in-production